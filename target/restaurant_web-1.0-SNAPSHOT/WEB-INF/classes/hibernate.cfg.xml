<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <!-- ============================================ -->
        <!-- Supabase PostgreSQL Connection (Pooler)      -->
        <!-- ============================================ -->
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        <property name="hibernate.connection.url">jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require&amp;prepareThreshold=0</property>
        <property name="hibernate.connection.username">postgres.bstcdtpgtbvpsitnogzd</property>
        <property name="hibernate.connection.password">quynhloc2310</property>

        <!-- Hibernate Settings -->
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</property>
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <!-- UPDATE: tự tạo/cập nhật bảng. Đổi thành 'validate' sau lần chạy đầu -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Connection Pool -->
        <property name="hibernate.c3p0.min_size">2</property>
        <property name="hibernate.c3p0.max_size">10</property>
        <property name="hibernate.c3p0.timeout">300</property>

        <!-- Entity Mappings -->
        <mapping class="market.restaurant_web.entity.Role"/>
        <mapping class="market.restaurant_web.entity.User"/>
        <mapping class="market.restaurant_web.entity.Area"/>
        <mapping class="market.restaurant_web.entity.DiningTable"/>
        <mapping class="market.restaurant_web.entity.Category"/>
        <mapping class="market.restaurant_web.entity.Product"/>
        <mapping class="market.restaurant_web.entity.Order"/>
        <mapping class="market.restaurant_web.entity.OrderDetail"/>
        <mapping class="market.restaurant_web.entity.Payment"/>
        <mapping class="market.restaurant_web.entity.UserSession"/>
        <mapping class="market.restaurant_web.entity.Booking"/>
        <mapping class="market.restaurant_web.entity.PreOrderItem"/>
        <mapping class="market.restaurant_web.entity.SystemConfig"/>
        <mapping class="market.restaurant_web.entity.Permission"/>
        <mapping class="market.restaurant_web.entity.AuditLog"/>
    </session-factory>
</hibernate-configuration>
